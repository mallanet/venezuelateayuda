# Base de datos (Neon/Supabase/Vercel Postgres — usar URL pooled en DATABASE_URL)
DATABASE_URL="postgresql://user:pass@host:5432/db?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:pass@host:5432/db?sslmode=require"

# Auth (NextAuth v5) — generar con: openssl rand -hex 32
AUTH_SECRET="genera-uno-con-openssl-rand-hex-32"
# En Vercel: URL pública del sitio (sin barra final)
AUTH_URL="https://tu-dominio.vercel.app"
NEXT_PUBLIC_APP_URL="https://tu-dominio.vercel.app"

EMAIL_FROM="no-reply@venezuelateayuda.org"

# Email de verificación (elige UNO)
# Resend: https://resend.com — dominio verificado
# RESEND_API_KEY="re_xxxxxxxx"
# O SMTP (Hostinger Email: smtp.hostinger.com:465)
# SMTP_HOST="smtp.hostinger.com"
# SMTP_PORT="465"
# SMTP_USERNAME="no-reply@venezuelateayuda.org"
# SMTP_PASSWORD="clave-del-buzon"
# SMTP_FROM="Venezuela Te Ayuda <no-reply@venezuelateayuda.org>"

# WhatsApp de contacto (formato internacional sin +, ej. 584241234567)
# NEXT_PUBLIC_WHATSAPP_NUMBER="584241234567"

# Credenciales del admin creado por `npm run seed` (solo desarrollo)
# ADMIN_EMAIL="admin@venezuelateayuda.org"
# ADMIN_PASSWORD="cambia-esta-clave"
