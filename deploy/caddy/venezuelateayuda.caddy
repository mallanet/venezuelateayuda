venezuelateayuda.org, www.venezuelateayuda.org {
	encode zstd gzip
	import security_headers

	@nextStatic path /_next/static/*
	header @nextStatic Cache-Control "public, max-age=31536000, immutable"

	@notStatic not path /_next/static/*
	header @notStatic Cache-Control "no-cache, must-revalidate"

	reverse_proxy venezuelateayuda-app-1:3000
}
